{
  "name": "sql-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Custom agent that generates SQL for a SQLite database, built on the pi agent harness",
  "scripts": {
    "seed": "node seed-example-db.ts",
    "start": "node --env-file-if-exists=.env sql-agent.ts",
    "tui": "node --env-file-if-exists=.env tui.ts",
    "web": "node --env-file-if-exists=.env web-server.ts",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.81.1",
    "@earendil-works/pi-ai": "^0.81.1",
    "typebox": "1.1.38"
  }
}
